<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="qp_public_form_page" name="QP Public Form Page">
        <t t-call="website.layout">
            <div class="container my-5">
                <div class="row justify-content-center">
                    <div class="col-lg-8">
                        <h1 class="mb-4 text-center">Quality Patch Order Tracking Form</h1>

                        <form action="/qp/public-form/submit" method="post" class="oe_website_form">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                            <div class="mb-3">
                                <label class="form-label">Order No</label>
                                <input type="text" name="order_no" class="form-control" required="required"/>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Good Pcs</label>
                                <input type="number" name="good_pcs" class="form-control" required="required"/>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Rejected Pcs</label>
                                <input type="number" name="rejected_pcs" class="form-control" required="required"/>
                            </div>

                            <div class="text-center">
                                <button type="submit" class="btn btn-primary px-5">Submit</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="qp_public_form_thank_you" name="QP Public Form Thank You">
        <t t-call="website.layout">
            <div class="container my-5 text-center">
                <h2>Thank You</h2>
                <p>Your record has been submitted successfully.</p>
                <a href="/qp/public-form" class="btn btn-primary">Submit Another Record</a>
            </div>
        </t>
    </template>
</odoo>
